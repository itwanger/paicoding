# Copy this file to `.env` for local development.
# The app auto-loads `.env` and `.env.local` from the repository root before Spring starts.
# `launch.sh` and `deploy.sh` will also source these files before starting the jar.

# AI providers
PAICODING_OPENAI_API_KEY=
PAICODING_ZHIPU_API_SECRET_KEY=
PAICODING_XUNFEI_APP_ID=
PAICODING_XUNFEI_API_KEY=
PAICODING_XUNFEI_API_SECRET=
PAICODING_XUNFEI_API_PASSWORD=
PAICODING_DEEPSEEK_API_KEY=
PAICODING_DOUBAO_API_KEY=
PAICODING_DOUBAO_ENDPOINT=

# Login / auth
PAICODING_WX_APP_SECRET=

# Storage
PAICODING_OSS_AK=
PAICODING_OSS_SK=
PAICODING_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
PAICODING_OSS_BUCKET=
PAICODING_OSS_HOST=

# Database
PAICODING_DB_PASSWORD=

# Elasticsearch
# Share PaiSmart local Elasticsearch 8.10 by setting PAICODING_ES_OPEN=true
# and filling the same username/password.
PAICODING_ES_OPEN=false
PAICODING_ES_HOSTS=127.0.0.1:9200
PAICODING_ES_SCHEME=https
PAICODING_ES_USERNAME=elastic
PAICODING_ES_PASSWORD=
PAICODING_ES_API_COMPATIBILITY_MODE=true
PAICODING_ES_INSECURE_TRUST_ALL_CERTIFICATES=true

# Optional local Elasticsearch process settings for ./start-elasticsearch.sh
ES_HOME=/Users/itwanger/Downloads/elasticsearch-8.10.0
ES_HTTP_PORT=9200
ES_TRANSPORT_PORT=9300
ES_JAVA_OPTS="-Xms500M -Xmx500M"

# Optional aliases for standalone tools/tests
OPENAI_API_KEY=

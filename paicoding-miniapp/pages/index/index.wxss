.t-input {
  --td-input-vertical-padding: 24rpx;
}

.index-page {
  padding-bottom: 0;
}

.header {
  position: relative;
  margin-bottom: 60rpx;
}

.header-title {
  color: white;
  font-size: 60rpx;
  font-weight: bold;
  position: absolute;
  z-index: 1;
  top: 36%;
  left: 60rpx;
}

.header-subtitle {
  color: white;
  font-size: 28rpx;
  position: absolute;
  z-index: 1;
  top: 55%;
  left: 60rpx;
}

.search-wrapper {
  position: absolute;
  bottom: -48rpx;
}

.search {
  border-radius: 100px;
  width: calc(100vw - 60rpx);
  margin-left: 30rpx;
}

.category-sticky-sentinel {
  height: 1px;
}

.category-sticky {
  position: sticky;
  top: 0;
  z-index: 20;
  width: 100vw;
}

.category-sticky--stuck {
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.08);
}

.category-row {
  height: 100%;
  white-space: nowrap;
  overflow: hidden;
}

.category-track {
  position: relative;
  display: inline-flex;
  align-items: flex-end;
  min-width: 100%;
  height: 100%;
  padding: 0 30rpx 38rpx 30rpx;
  box-sizing: border-box;
}

.category-pill {
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 50rpx;
  padding: 0 24rpx;
  color: #334155;
}

.category-pill--active {
  font-size: 32rpx;
  font-weight: bold;
}

.active-bar {
  width: 16px;
  height: 8rpx;
  background: linear-gradient(to left, #0BC196, #1CE885);
  border-radius: 10rpx;
  position: absolute;
  bottom: 18rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.article-card {
  width: calc(100vw - 60rpx);
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  margin-left: 30rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  border-radius: 20rpx;
  box-shadow: 0px 0px 8px #99999920;
  background-color: #fff;
}

.title {
  color: #111827;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cover {
  width: 24vw;
  height: 18vw;
  border-radius: 14rpx;
}

.article-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 20rpx 0;
}

.avatar-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #333;
  font-weight: 500;
}

.avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 100rpx;
  background-color: #e5e7eb;
}

.summary-wrapper {
  flex: 1;
}

.summary {
  margin-top: 12rpx;
  color: #666;
  font-size: 26rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.footer {
  display: flex;
  justify-content: space-between;
}

.tag {
  font-size: 24rpx;
  color: #0BC196;
  background-color: #0BC19620;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  color: #999;
  font-size: 24rpx;
}

.empty {
  padding: 80rpx 0;
  color: #64748b;
  text-align: center;
}

.load-state {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

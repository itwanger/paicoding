.collection-page {
  padding-bottom: 0;
}

.collection-scroll {
  height: calc(100vh - 24rpx);
}

.collection-card {
  display: flex;
  min-height: 224rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.cover {
  width: 220rpx;
  height: 224rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.article-body {
  flex: 1;
  min-width: 0;
  padding: 22rpx;
}

.title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 42rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.summary {
  margin-top: 10rpx;
  color: #475569;
  font-size: 25rpx;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 23rpx;
}

.remove-button {
  width: 148rpx;
  height: 58rpx;
  margin-top: 14rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 56rpx;
}

.remove-button[disabled] {
  opacity: 0.56;
}

.empty {
  padding: 80rpx 0;
  color: #64748b;
  text-align: center;
}

.load-state {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}
